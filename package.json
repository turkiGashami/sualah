{
  "name": "sualah",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.2",
  "description": "سُعلاة — Arabic web party game: hidden-roles social deduction (Arabian folklore)",
  "scripts": {
    "dev": "pnpm --filter @sualah/web dev",
    "build": "pnpm --filter @sualah/web build && node scripts/prepare-standalone.mjs",
    "start": "node apps/web/.next/standalone/apps/web/server.js",
    "test": "pnpm --filter @sualah/game-core test",
    "test:watch": "pnpm --filter @sualah/game-core test -- --watch",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "e2e": "pnpm --filter @sualah/web e2e",
    "build:edge": "node scripts/build-edge-shared.mjs",
    "pentest": "tsx --env-file=.env.local supabase/tests/pentest.ts"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
