# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Analytics 4 Measurement ID (optional; analytics off if empty)
NEXT_PUBLIC_GA_ID=

# Supabase — SERVER ONLY. Never import into client code. Used by Edge Functions
# and the pen-test script. Bypasses RLS — treat as the master key.
SUPABASE_SERVICE_ROLE_KEY=

# Project ref (for CLI / scripts)
SUPABASE_PROJECT_REF=
